# 模板：复制为 application-local.yml 后填入真实值（application-local.yml 已加入 .gitignore）
#
# 新部署用户:除 spring.datasource.* 三行外,所有第三方密钥(LLM 中转、对象存储、语音 TTS、
# Jamendo BGM、浏览器插件 token 等)启动后端后在前端「系统设置」页面填写,会落到 app_config 表。
spring:
  datasource:
    url: "jdbc:mysql://127.0.0.1:3306/auteur?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true"
    username: root
    password: REPLACE_ME

# 以下字段属于"每个部署不一样,但又不太敏感"的技术参数,可选保留 yml 也可空:
# auteur:
#   video:
#     ffmpeg:
#       binary-path: /opt/homebrew/bin/ffmpeg   # macOS Homebrew;Linux 一般 /usr/bin/ffmpeg
#     remotion:
#       enabled: true                          # 关掉跑测试用 false
#       renderer-dir: ./renderer
#       public-base-url: http://localhost:8081 # backend 对外可达地址,Remotion 拉素材用
