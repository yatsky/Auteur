# --- Secrets (NEVER commit) ---
backend/src/main/resources/application-local.yml
**/application-local.yml
*.env
.env
.env.local

# --- 本机专属内容 / 私有预设 / 个人脚本 ---
# .local/ 下放只属于本机器的东西:私有预设 seed 文件、一次性 setup 脚本、未公开的笔记等。
# 用 / 锚定到仓库根,只忽略根目录下的 .local;子目录里的 .local(若有同名)不受影响。
/.local/

# --- Generated assets (TTS / video / etc) ---
# 必须用前导 / 锚定到 git 根,否则会误伤 Java 包 com.auteur.storage(backend/src/main/java/com/auteur/storage/)
/backend/storage/
/storage/

# --- Build output ---
target/
build/
out/
*.class
*.jar
*.war
*.log

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/
.claude/

# --- Local sandbox / experiments ---
# 锚定到根:不要误伤 backend/src/test/(Maven 标准测试目录)
/test/
backend/scripts/archive/

# --- OS ---
.DS_Store
Thumbs.db

# --- Pencil temp ---
*.pen.bak
