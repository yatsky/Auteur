  "subtitleCues": [
    { "startSec": 0,  "endSec": 4,  "text": "顺治十一年,三月十八日。" },
    { "startSec": 5,  "endSec": 9,  "text": "朕,是大清第四位皇帝。" },
    { "startSec": 10, "endSec": 14, "text": "八岁那年,父皇驾崩。" },
    { "startSec": 15, "endSec": 19, "text": "满朝文武,无人敢与朕对视。" },
    { "startSec": 20, "endSec": 24, "text": "鳌拜跋扈,辅政四臣已成尾大不掉之势。" },
    { "startSec": 25, "endSec": 29, "text": "朕只能等。等到自己,足够强。" }
  ],
